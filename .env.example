# NexDown configuration — copy to .env and adjust

# Security (required in production)
SECRET_KEY=change-this-to-a-random-secret

# Server
HOST=0.0.0.0
PORT=5000
FLASK_DEBUG=0

# Storage
DOWNLOADS_DIR=./downloads
MAX_FILE_AGE_HOURS=2
MIN_DISK_FREE_MB=500

# Download limits
MAX_CONCURRENT_DOWNLOADS=5
MAX_BATCH_SIZE=10
MAX_QUEUE_DEPTH=50

# Task memory retention (seconds after completion)
TASK_RETENTION_SECS=1800

# Background cleanup interval (seconds)
CLEANUP_INTERVAL_SECS=600

# Rate limiter backend (memory:// or redis://localhost:6379)
RATE_LIMIT_STORAGE=memory://
